# Root gitignore for the full project

# Node.js
node_modules/
pnpm-lock.yaml
yarn.lock
package-lock.json

# Backend dependencies and build artifacts
/back/node_modules/
/back/vendor/
/back/public/build/
/back/public/hot/
/back/public/storage/
/back/.phpunit.cache
/back/.phpactor.json
/back/.vscode/
/back/.idea/
/back/.nova/

# Frontend dependencies and build artifacts
/front/node_modules/
/front/dist/
/front/dist-ssr/
/front/.vite/
/front/.turbo/

# Environment and secrets
*.env
.env.*
/back/.env
/back/.env.*
/front/.env
/front/.env.*

# Laravel storage and cache
/back/storage/
/back/bootstrap/cache/
/back/storage/*.key
/back/storage/pail
/back/storage/app/public
/back/storage/debugbar
/back/vendor/

# System files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE/editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
/back/storage/logs/

# PHP
/.phpunit.result.cache
/phpunit.xml.cache

# Misc
/.fleet
